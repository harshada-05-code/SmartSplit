rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Development / demo: app does not use Firebase Auth yet.
    // Replace with auth-based rules (or App Check) before production.
    match /groups/{groupId} {
      allow read, write: if true;
    }
    match /expenses/{expenseId} {
      allow read, write: if true;
    }
  }
}
